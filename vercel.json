{
  "crons": [
    { "path": "/api/cron/editor-agent", "schedule": "0 9 * * *" },
    { "path": "/api/cron/writer-agent", "schedule": "0 11 * * *" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "all"
        }
      ]
    }
  ]
}
